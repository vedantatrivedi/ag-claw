OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Model Configuration
OPENAI_MODEL=gpt-4o-mini  # Fast and cheap. Use gpt-4o for better quality.

# Agent Configuration
PLANNER_TEMPERATURE=0.3
BROWSER_TEMPERATURE=0.5

# Logging
LOG_LEVEL=INFO

# Browser Search Configuration (optional)
BROWSER_SEARCH_ENABLED=true
BROWSER_HEADLESS=true
BROWSER_SEARCH_TIMEOUT=30
MAX_PARALLEL_SEARCHES=3

# Discord Bot Configuration
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_ID=  # Optional: restrict bot to a specific channel ID

# Pine Labs / Plural Configuration
PLURAL_ENV=uat
PLURAL_CLIENT_ID=your-client-id
PLURAL_CLIENT_SECRET=your-client-secret
PLURAL_CALLBACK_URL=https://example.com/callback
PLURAL_FAILURE_CALLBACK_URL=https://example.com/failure
PLURAL_TEST_EMAIL=test@example.com
PLURAL_TEST_FIRST_NAME=Test
PLURAL_TEST_CUSTOMER_ID=cust-preauth-001
PLURAL_TEST_MOBILE=9876543210
PLURAL_TEST_AMOUNT_PAISA=10000
PLURAL_TEST_CAPTURE_PAISA=6000
PLURAL_TEST_NOTES="Agent shopping pre-auth"
PLURAL_TEST_TIMEOUT_SECONDS=300
PLURAL_TEST_POLL_SECONDS=5
PLURAL_HTTP_TIMEOUT_SECONDS=30
PLURAL_TOOL_FLOW=shopping-agent
