# OpenAI API Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=  # Optional: Custom base URL (e.g., for Bedrock, Azure, etc.)

# Model Configuration
OPENAI_MODEL=gpt-4o-mini  # Fast and cheap. Use gpt-4o for better quality.

# Agent Configuration
PLANNER_TEMPERATURE=0.3
BROWSER_TEMPERATURE=0.5

# Logging
LOG_LEVEL=INFO

# Browser Search Configuration (optional)
BROWSER_SEARCH_ENABLED=true
BROWSER_HEADLESS=true
BROWSER_SEARCH_TIMEOUT=30
MAX_PARALLEL_SEARCHES=3

# Discord Bot Configuration
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_ID=  # Optional: restrict bot to a specific channel ID
